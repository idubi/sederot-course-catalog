---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadApprovedCatalog } from '../content/catalog-loader';
import { buildProgramSummaries } from '../domain/public-catalog';
import SelectionFunnel from '../components/SelectionFunnel.astro';

const catalog = loadApprovedCatalog();
const programs = buildProgramSummaries(catalog);
---

<BaseLayout
  title="קטלוג תוכניות וקורסים | מרכז המצוינות שדרות"
  description="קטלוג התוכניות והקורסים של מרכז המצוינות שדרות"
>
  <section class="hero" aria-labelledby="page-title">
    <div>
      <p class="kicker">{catalog.academicYear.label}</p>
      <h1 id="page-title">בוחרים תוכנית ומגלים את אשכול הקורסים המתאים</h1>
      <p class="intro">
        מתחילים בבחירת תוכנית, ולאחר מכן שכבה וקבוצת קהל. הבחירה היא לצורכי
        ניווט בלבד ואינה נשמרת כמידע אישי.
      </p>
    </div>
    <aside class="status-card" aria-label="מצב הקטלוג">
      <strong>{programs.length} תוכניות בקטלוג המאושר</strong>
      <span>התוכן נטען בזמן הבנייה בלבד, ללא שרת או איסוף מידע.</span>
    </aside>
  </section>
  <section class="programs" aria-labelledby="programs-title">
    <div class="section-heading">
      <p class="kicker">שלב ראשון</p>
      <h2 id="programs-title">בחירת תוכנית</h2>
    </div>
    <div class="program-grid">
      {
        programs.map((program) => (
          <article class="program-card">
            <p>{program.category === 'gifted' ? 'מחוננים' : 'מצטיינים'}</p>
            <h3>{program.name}</h3>
            <dl>
              <div>
                <>
                  <dt>קבוצות</dt>
                  <dd>{program.groupCount}</dd>
                </>
              </div>
              <div>
                <>
                  <dt>שיוכי קורסים</dt>
                  <dd>{program.offeringCount}</dd>
                </>
              </div>
            </dl>
            <span class="next-step">בחירת שכבה וקהל תיפתח בשלב הבא</span>
          </article>
        ))
      }
    </div>
    <SelectionFunnel catalog={catalog} />
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    gap: 1.5rem;
    padding: clamp(1.5rem, 7vw, 4rem) 0;
  }

  .kicker {
    margin: 0 0 0.5rem;
    color: #315c9c;
    font-weight: 700;
  }

  h1 {
    max-width: 18ch;
    margin: 0;
    font-size: clamp(2rem, 9vw, 4.5rem);
    line-height: 1.08;
  }

  .intro {
    max-width: 46rem;
    margin: 1.25rem 0 0;
    color: #52617a;
    font-size: clamp(1rem, 3vw, 1.25rem);
  }

  .status-card {
    display: grid;
    gap: 0.4rem;
    align-self: end;
    padding: 1.25rem;
    border: 1px solid #cbd6e8;
    border-radius: 1rem;
    background: #fff;
    box-shadow: 0 1rem 2.5rem rgb(35 62 105 / 8%);
  }

  .status-card strong {
    color: #315c9c;
  }

  .programs {
    padding-block: 1rem 4rem;
  }
  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.7rem, 6vw, 2.7rem);
  }
  .program-grid {
    display: grid;
    gap: 1rem;
    margin-block-start: 1.25rem;
  }
  .program-card {
    padding: 1.25rem;
    border: 1px solid #cbd6e8;
    border-radius: 1rem;
    background: #fff;
  }
  .program-card p,
  .program-card h3 {
    margin-block: 0 0.4rem;
  }
  .program-card dl {
    display: flex;
    gap: 1.5rem;
    margin-block: 1rem;
  }
  .program-card dl div {
    display: grid;
  }
  .program-card dt,
  .next-step {
    color: #52617a;
    font-size: 0.875rem;
  }
  .program-card dd {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 800;
  }

  @media (min-width: 48rem) {
    .hero {
      grid-template-columns: minmax(0, 2fr) minmax(16rem, 1fr);
      min-height: 65vh;
    }
    .program-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
