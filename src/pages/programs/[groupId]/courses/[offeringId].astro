---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ContactActions from '../../../../components/ContactActions.astro';
import { loadApprovedCatalog } from '../../../../content/catalog-loader';
import {
  buildProgramGroups,
  type OfferingViewModel,
  type ProgramGroupViewModel,
} from '../../../../domain/public-catalog';

interface CourseDetailProps {
  group: ProgramGroupViewModel;
  offering: OfferingViewModel;
}

export function getStaticPaths() {
  return buildProgramGroups(loadApprovedCatalog()).flatMap((group) =>
    group.offerings.map((offering) => ({
      params: {
        groupId: group.groupId,
        offeringId: offering.offeringId,
      },
      props: { group, offering },
    })),
  );
}

const { group, offering } = Astro.props as CourseDetailProps;
const catalog = loadApprovedCatalog();
const base = import.meta.env.BASE_URL;
const semesterLabels = {
  annual: 'שנתי',
  first: 'מחצית א׳',
  second: 'מחצית ב׳',
};
---

<BaseLayout
  title={`${offering.courseName} | ${group.programName}`}
  description={`פרטי הקורס ${offering.courseName} במסגרת ${group.programName}`}
>
  <nav aria-label="פירורי לחם">
    <a href={`${base}programs/${group.groupId}/`}>חזרה אל {group.programName}</a
    >
  </nav>
  <article class="course-detail">
    {
      offering.image && (
        <img
          src={`${base}${offering.image.src.slice(1)}`}
          alt={offering.image.alt}
        />
      )
    }
    <div class="course-content">
      <p class="context">
        {group.programName} · {group.gradeLabels.join(', ')}
      </p>
      <p class="short-name">{offering.shortName}</p>
      <h1>{offering.courseName}</h1>
      <dl>
        <div>
          <dt>מנחים</dt>
          <dd>{offering.instructors.join(', ')}</dd>
        </div>
        <div>
          <dt>תקופה</dt>
          <dd>{semesterLabels[offering.semester]}</dd>
        </div>
      </dl>
      <section aria-labelledby="description-title">
        <h2 id="description-title">על הקורס</h2>
        <div class="description" set:html={offering.descriptionHtml} />
      </section>
      <a class="back-link" href={`${base}programs/${group.groupId}/`}
        >חזרה לאשכול הקורסים של התוכנית</a
      >
    </div>
  </article>
  <ContactActions
    contacts={catalog.contacts}
    programName={group.programName}
    gradeLabels={group.gradeLabels}
    courseName={offering.courseName}
  />
</BaseLayout>

<style>
  nav {
    padding-block: 1rem;
  }
  .course-detail {
    overflow: hidden;
    margin-block-end: 3rem;
    border: 1px solid #cbd6e8;
    border-radius: 1.2rem;
    background: #fff;
  }
  img {
    width: 100%;
    max-height: 28rem;
    object-fit: cover;
  }
  .course-content {
    padding: clamp(1.25rem, 5vw, 3rem);
  }
  .context,
  .short-name,
  h1 {
    margin-block: 0 0.5rem;
  }
  .context {
    color: #4b5870;
  }
  .short-name {
    color: #315c9c;
    font-weight: 800;
  }
  h1 {
    font-size: clamp(2rem, 8vw, 4rem);
  }
  dl {
    display: grid;
    gap: 0.7rem;
    margin-block: 1.5rem;
  }
  dl div {
    display: flex;
    gap: 0.5rem;
  }
  dt {
    font-weight: 800;
  }
  dd {
    margin: 0;
  }
  section {
    margin-block: 2rem;
  }
  .description :global(a) {
    overflow-wrap: anywhere;
  }
  .back-link {
    display: inline-block;
    padding: 0.7rem 1rem;
    border: 1px solid #315c9c;
    border-radius: 0.6rem;
    font-weight: 700;
    text-decoration: none;
  }
  @media (min-width: 48rem) {
    dl {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
