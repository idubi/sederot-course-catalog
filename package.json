{
  "name": "sderot-course-catalog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "editor": "vite --config tools/content-editor/vite.config.ts",
    "build": "npm run content:validate && astro check && astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && npm run format:check",
    "test": "vitest run --passWithNoTests",
    "content:read-source": "node --import tsx tools/source-reader/write-blueprint-snapshot.ts",
    "content:normalize-source": "node --import tsx tools/source-normalizer/write-normalized-draft.ts",
    "content:import-draft": "node --import tsx tools/source-diagnostics/write-import-artifacts.ts",
    "content:validate": "node --import tsx src/content/validate-approved.ts",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "astro": "7.1.3",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "1.7.0",
    "prettier": "3.9.6",
    "prettier-plugin-astro": "0.14.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@types/sanitize-html": "2.16.1",
    "sanitize-html": "2.17.6",
    "zod": "4.4.3"
  }
}
