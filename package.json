{
  "name": "sderot-course-catalog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run content:validate && astro check && astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && npm run format:check",
    "test": "vitest run --passWithNoTests",
    "content:validate": "node --import tsx src/content/validate-approved.ts",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "astro": "7.1.3",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "1.7.0",
    "prettier": "3.9.6",
    "prettier-plugin-astro": "0.14.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
